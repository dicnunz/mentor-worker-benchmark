{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mentor-worker-benchmark task pack v2 metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_name",
    "pack_version",
    "generator_seed",
    "categories",
    "counts",
    "category_counts",
    "source_audit",
    "tasks"
  ],
  "properties": {
    "pack_name": {
      "type": "string",
      "const": "task_pack_v2"
    },
    "pack_version": {
      "type": "string"
    },
    "generator_seed": {
      "type": "integer"
    },
    "categories": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "string_regex_parsing",
          "ds_algo",
          "file_io_serialization",
          "concurrency_basics",
          "numerical_edge_cases",
          "multi_file_mini_module",
          "mini_repo_bugfix",
          "mini_repo_feature",
          "mini_repo_cli",
          "mini_repo_tool_sim"
        ]
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "train",
        "dev",
        "test",
        "quick"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "const": 473
        },
        "train": {
          "type": "integer",
          "const": 265
        },
        "dev": {
          "type": "integer",
          "const": 104
        },
        "test": {
          "type": "integer",
          "const": 104
        },
        "quick": {
          "type": "integer",
          "const": 30
        }
      }
    },
    "category_counts": {
      "type": "object"
    },
    "source_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_tasks",
        "exact_family_count",
        "duplicate_families_detected",
        "family_size_distribution",
        "duplicate_tasks_removed",
        "cross_split_overlap"
      ],
      "properties": {
        "total_tasks": {
          "type": "integer",
          "const": 652
        },
        "exact_family_count": {
          "type": "integer",
          "const": 473
        },
        "duplicate_families_detected": {
          "type": "integer"
        },
        "family_size_distribution": {
          "type": "object"
        },
        "duplicate_tasks_removed": {
          "type": "integer"
        },
        "cross_split_overlap": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "family_count",
            "task_count",
            "split_pattern_counts"
          ],
          "properties": {
            "family_count": {
              "type": "integer"
            },
            "task_count": {
              "type": "integer"
            },
            "split_pattern_counts": {
              "type": "object"
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 473,
      "maxItems": 473,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "category",
          "difficulty",
          "family_id",
          "split",
          "quick",
          "path"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^(v1_[a-z_]+_[0-9]{3}|v2_mini_[a-z_]+_[0-9]{3})$"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "string_regex_parsing",
              "ds_algo",
              "file_io_serialization",
              "concurrency_basics",
              "numerical_edge_cases",
              "multi_file_mini_module",
              "mini_repo_bugfix",
              "mini_repo_feature",
              "mini_repo_cli",
              "mini_repo_tool_sim"
            ]
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "easy",
              "medium",
              "hard"
            ]
          },
          "family_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "split": {
            "type": "string",
            "enum": [
              "train",
              "dev",
              "test"
            ]
          },
          "quick": {
            "type": "boolean"
          },
          "path": {
            "type": "string",
            "pattern": "^tasks/(v1_[a-z_]+_[0-9]{3}|v2_mini_[a-z_]+_[0-9]{3})$"
          }
        }
      }
    }
  }
}
